//
//  Secrets.xcconfig
//  Plink
//
//  🔧 NEW: Configuration file for sensitive API keys.
//  Copy this file to Secrets.xcconfig (without .template) and fill in real values.
//  Secrets.xcconfig is gitignored — never commit real API keys.
//
//  How to use:
//    1. Copy this template: cp Secrets.xcconfig.template Secrets.xcconfig
//    2. Fill in your real API keys below
//    3. Add Secrets.xcconfig to your Xcode project's configuration
//       (Project → Info → Configurations → select for Debug + Release)
//
//  The keys are read at runtime from Info.plist (which references $(KEY_NAME)).
//

// OpenRouter API key for AI features (ИИ-помощник + AI-поиск на Home)
// Get your key at https://openrouter.ai/keys
PLINK_AI_API_KEY = sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE

// Yandex OAuth client ID (for Yandex sign-in)
// Register at https://oauth.yandex.ru/client/new
YANDEX_CLIENT_ID = your_yandex_client_id_here
