{
  "name": "plink-server",
  "version": "1.5.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "npx prisma generate && npx tsx src/index.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
