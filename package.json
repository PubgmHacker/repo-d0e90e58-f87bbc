    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.40.0",
    "bcrypt": "^5.1.1",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "nanoid": "^5.0.9",
    "pino-pretty": "^11.3.0",
    "prom-client": "^15.1.3",
    "tsx": "^4.19.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.5",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.5"
