# ─────────────────────────────────────────────────────────────────────────────
# Plink backend — environment template
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=8080

# Database
DATABASE_URL="postgresql://user:pass@host:port/dbname"

# Redis (required for multi-replica realtime state — see Stage 3)
REDIS_URL="redis://localhost:6379"

# JWT
# MUST be >=32 chars in production; server refuses to boot on default/weak secret.
JWT_SECRET="replace-with-strong-32-char-min-secret"
JWT_ISSUER=plink
# Comma-separated allowlist of audiences accepted on access tokens.
# Allows safe rollout across iOS / Android / desktop without re-issuing tokens.
JWT_AUDIENCES=plink-ios,plink-android,plink-desktop

# CORS — allowlist in production; dev reflects any origin automatically.
# Tauri desktop origins (tauri://localhost, http://tauri.localhost) are always allowed for WebSocket.
CORS_ORIGIN="https://app.plink.example,https://staging.plink.example,https://plink.vercel.app"

# Public API base URL (avatar links, OpenAPI)
PUBLIC_BASE_URL="https://plink-backend-production-ef31.up.railway.app"

# Dev emergency DB wipe — POST /api/dev/wipe-db { "secret": "..." }
DEV_WIPE_SECRET="change-me-before-testing"
# Set true on Railway to allow wipe-db in production (multi-device test resets)
ENABLE_DEV_WIPE=false

# Feature flags — see §15 rollout plan
APP_STORE_COMPLIANT=true
ENABLE_LEGACY_STREAM_RELAY=false
REALTIME_PROTOCOL_V2=true
NATIVE_PLAYER_V2=true
LIVEKIT_SFU=false
WATCH_SCREEN_V2=false

# B5: AI structured actions feature flag.
# Set to true ONLY after function/tool calling is implemented.
# Default: false (keyword detection is prototype, not for external beta).
AI_ACTIONS_ENABLED=false

# B1: Bootstrap admin allowlist (comma-separated emails).
# Used by scripts/bootstrap-admin.js. Only emails in this list can be
# promoted to ADMIN/FOUNDER via the bootstrap script.
ALLOWED_BOOTSTRAP_ADMINS=koslakandrej@gmail.com

# AI
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
AI_MODEL=openai/gpt-4o-mini

# LiveKit (Stage 9)
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Observability
SENTRY_DSN=""
OTEL_ENDPOINT=""

# Media (signed URL TTL in seconds; 60-300)
SIGNED_MEDIA_URL_TTL=120
